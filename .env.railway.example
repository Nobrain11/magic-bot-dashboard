# ─────────────────────────────────────────────────────────────
# $MAGIC Bot — Railway Environment Variables
# Copy these into your Railway service → Variables tab
# ─────────────────────────────────────────────────────────────

# Required — Railway injects this automatically (do NOT set manually)
# PORT=8080

# Required — PostgreSQL connection string
# Railway: add a Postgres plugin → it sets DATABASE_URL automatically
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Required — random secret for session signing (generate with: openssl rand -hex 32)
SESSION_SECRET=change_me_to_a_random_secret

# Required — tells Express to enable static file serving + production mode
NODE_ENV=production

# Optional — your Solana RPC endpoint (set this in bot config via the dashboard)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
